{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PulseRing",
  "version": "1.0.0",
  "identifier": "com.codex.superlitestatusbar",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "PulseRing Settings",
        "url": "index.html#settings",
        "width": 760,
        "height": 520,
        "visible": false,
        "decorations": true,
        "resizable": true
      },
      {
        "label": "tooltip",
        "title": "Status Tooltip",
        "url": "index.html#tooltip",
        "width": 300,
        "height": 124,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      },
      {
        "label": "floating",
        "title": "Status Floating Bar",
        "url": "index.html#floating",
        "width": 312,
        "height": 44,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg"],
    "icon": [
      "icons/16x16.png",
      "icons/24x24.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Quiet system status monitor.",
    "longDescription": "A quiet Windows tray and macOS menu bar system status monitor."
  }
}
