{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for the tray monitor windows.",
  "windows": ["settings", "floating", "tooltip"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "autostart:allow-enable",
